{
  "name": "crypto-liquidity-audit-ui",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && vite-node scripts/prerender-static.ts && tsx scripts/generate-sitemap.ts",
    "preview": "vite preview",
    "preview:worker": "npm run build && wrangler dev",
    "deploy": "wrangler deploy",
    "sync:data": "tsx scripts/sync-analysis-data.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@posthog/react": "^1.10.3",
    "@sentry/react": "^10.62.0",
    "posthog-js": "^1.395.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.18.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "jsdom": "^26.1.0",
    "tsx": "^4.19.4",
    "typescript": "^5.5.3",
    "vite": "^8.1.2",
    "vite-node": "^5.3.0",
    "vitest": "^4.1.5",
    "wrangler": "^4.105.0"
  }
}
