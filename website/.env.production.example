# Public site origin (no trailing slash). Required for production builds.
VITE_SITE_URL=https://crypto-liquidity-audit.drakkar.software

# Public R2 base URL for analysis JSON (no trailing slash).
# Required for production builds — see vite.config.ts.
VITE_ANALYSIS_DATA_BASE=https://pub-xxxx.r2.dev

# PostHog EU Cloud. Required for production builds — token from PostHog project settings.
VITE_POSTHOG_KEY=
# Optional override; default is https://eu.i.posthog.com
# VITE_POSTHOG_HOST=https://eu.i.posthog.com

# Sentry (errors only). Required for production builds.
VITE_SENTRY_DSN=https://examplePublicKey@o0.ingest.de.sentry.io/0
